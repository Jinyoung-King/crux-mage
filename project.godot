; crux-mage — 레인 디펜스 + 로그라이트 카드 빌더 (1단계: 핵심 루프)
; Godot 4.6 / 웹(HTML5) 타깃이라 호환성 렌더러 사용

config_version=5

[application]

config/name="crux-mage"
run/main_scene="res://scenes/ui/start_screen.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.png"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[autoload]

GameState="*res://data/game_state.gd"
GameFeel="*res://scenes/fx/game_feel.gd"
Music="*res://scenes/fx/music.gd"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
